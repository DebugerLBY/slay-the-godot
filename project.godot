; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that are changed after launching the editor are not updated.

config_version=5

[application]
config/name="Slay the Godot"
config/version="0.1.0"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.6", "2d")
config/icon="res://icon.svg"

[autoload]
GameManager="res://scripts/managers/game_manager.gd"
CardDatabase="res://scripts/card_system/card_database.gd"

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720

[physics]
common/physics_engine="GodotPhysics2D"
